# Copy this file to .env and fill in your keys
# Never commit .env to GitHub!

# Your Anthropic API key (starts with sk-ant-)
CLAUDE_API_KEY=sk-ant-YOUR_KEY_HERE

# Your Groq API key (starts with gsk_) - free at console.groq.com
GROK_API_KEY=gsk_YOUR_KEY_HERE

# Your Google Gemini API key - free at aistudio.google.com
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Your Netlify frontend URL (no trailing slash)
FRONTEND_URL=https://your-site.netlify.app

# Port (Render sets this automatically, leave as 3001 for local)
PORT=3001

# Set to "production" on Render
NODE_ENV=development
